#include<iostream>
#include<cmath>
using namespace std;
int main()
{
    int Ntest;
    cin>>Ntest;
	while(Ntest!=0){ 
        Ntest=Ntest-1;
	int sum=0,g=0;
	int n; 
	cin>>n;
    while(n>0)
    {
        int k=n%10;
        sum=sum+k*pow(2,g);
        n=n/10;
        g++;

    }
    cout<<sum;
	}
    
}